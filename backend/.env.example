PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/securegate

GOOGLE_CLIENT_ID=CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/gmail/callback

JWT_SECRET=change_this_to_a_long_random_string_in_production
FRONTEND_URL=http://localhost:3000

# AI thresholds
BLOCK_THRESHOLD=80
QUARANTINE_THRESHOLD=50

# Gmail Sync
DEFAULT_SYNC_INTERVAL_SECONDS=30
MAX_EMAILS_PER_SYNC=50

# External AI (Gemini) fallback for uncertain emails
AI_PROVIDER=gemini
GEMINI_API_KEY=GEMINI_API_KEY_HERE

# Only call Gemini when risk_score is between these bounds (inclusive)
AI_UNCERTAIN_MIN=40
AI_UNCERTAIN_MAX=70

# Safety controls
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=512

